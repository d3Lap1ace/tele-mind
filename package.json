{
  "name": "tele-mind",
  "version": "1.0.0",
  "description": "Production-ready Telegram LLM Bot deployed on AWS EC2",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "tsc --watch",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs tele-mind",
    "pm2:monit": "pm2 monit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "security-check": "./scripts/security-check.sh",
    "setup-hooks": "./scripts/setup-hooks.sh"
  },
  "keywords": [
    "telegram",
    "bot",
    "llm",
    "ai",
    "openai",
    "anthropic",
    "ec2",
    "production"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "node-telegram-bot-api": "^0.66.0",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "zod": "^3.24.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.6",
    "@types/node-telegram-bot-api": "^0.66.0",
    "@types/express": "^5.0.0",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
